/* Counts the number of lowercase 'a' letters until '@' is reached */

#include <stdio.h>

int count_a(char str[]) {
    int i, sum = 0;

    for(i = 0; str[i] != '@'; i++) {
        if(str[i] == 'a') {
            sum = sum + 1;
        }
    }

    return sum;
}

int main(void) {
    char input[100];
    int total;

    printf("Enter a string (use '@' to stop): ");
    scanf("%99s", input); 

    total = count_a(input);

    printf("Number of 'a' letters: %d\n", total);

    return 0;
}
